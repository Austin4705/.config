#!/bin/bash

source "$CONFIG_DIR/colors.sh"
source "$CONFIG_DIR/icons.sh"

ITEM_DIR="$CONFIG_DIR/items"
PLUGIN_DIR="$CONFIG_DIR/plugins"

FONT="SF Pro"
PADDINGS=3

# CPU helper process
HELPER=git.felix.helper
killall helper 2>/dev/null
(cd $CONFIG_DIR/helper && make 2>/dev/null)
$CONFIG_DIR/helper/helper $HELPER >/dev/null 2>&1 &

# Unload macOS OSD overlay for volume changes
launchctl unload -F /System/Library/LaunchAgents/com.apple.OSDUIHelper.plist >/dev/null 2>&1 &

# Clear menu item cache on startup
rm -rf /tmp/sketchybar_menu_cache 2>/dev/null

# Aerospace workspace change event
sketchybar --add event aerospace_workspace_change

# Bar appearance
bar=(
  height=37
  blur_radius=30
  color=$BAR_COLOR
  border_width=0
  shadow=off
  position=top
  sticky=on
  padding_right=10
  padding_left=10
  margin=-2
  notch_width=200
  topmost=window
)

sketchybar --bar "${bar[@]}"

# Default item styling (hover-ready backgrounds)
defaults=(
  updates=when_shown
  icon.font="$FONT:Bold:14.0"
  icon.color=$ICON_COLOR
  icon.padding_left=$PADDINGS
  icon.padding_right=$PADDINGS
  label.font="$FONT:Semibold:13.0"
  label.color=$LABEL_COLOR
  label.padding_left=$PADDINGS
  label.padding_right=$PADDINGS
  padding_right=$PADDINGS
  padding_left=$PADDINGS
  background.height=26
  background.corner_radius=9
  background.border_width=0
  background.color=$HIGHLIGHT_COLOR
  background.drawing=off
  popup.background.border_width=2
  popup.background.corner_radius=9
  popup.background.border_color=$POPUP_BORDER_COLOR
  popup.background.color=$POPUP_BACKGROUND_COLOR
  popup.blur_radius=20
  popup.background.shadow.drawing=on
)

sketchybar --default "${defaults[@]}"

# ===== LEFT SIDE =====
# [Apple] [App Name] [File] [Edit] [View] ... [Spaces: X] ← flush with notch
source "$ITEM_DIR/apple.sh"
source "$ITEM_DIR/front_app.sh"
source "$ITEM_DIR/spaces.sh"

# ===== RIGHT SIDE (added rightmost first) =====
# Far right corner: Time | Battery% | WiFi | Sound Output | Volume | Bluetooth
source "$ITEM_DIR/calendar.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/wifi.sh"
source "$ITEM_DIR/sound_output.sh"
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/bluetooth.sh"
# Near notch: Network | Swap | Pressure | CPU graph
source "$ITEM_DIR/network.sh"
source "$ITEM_DIR/swap.sh"
source "$ITEM_DIR/pressure.sh"
source "$ITEM_DIR/cpu.sh"

sketchybar --update

# Trigger initial front_app detection so menu items populate immediately
(
  sleep 1
  CURRENT_APP=$(osascript -e 'tell application "System Events" to name of first process whose frontmost is true' 2>/dev/null)
  [ -n "$CURRENT_APP" ] && sketchybar --set front_app script="$PLUGIN_DIR/front_app.sh" && sketchybar --trigger front_app_switched
) &

echo "sketchybar configuration loaded.."
